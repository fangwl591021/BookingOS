# BookingOS environment example
#
# Current runtime configuration:
# - Cloudflare D1 is configured as binding `DB` in wrangler.toml.
# - The application currently reads D1 through env.DB.
# - LINE OA and LIFF values are stored in D1 settings tables, not in this file.
#
# Do not commit real tokens, passwords, Channel Secrets, Channel Access Tokens,
# LIFF IDs, or production credentials.

# Cloudflare D1 binding name. This is configured in wrangler.toml, not loaded
# from a local .env file by the Worker.
DB=configured-in-wrangler-toml

# Platform LINE OA values are managed in the platform console and stored in D1:
# - platform_line_oa_settings.basic_id
# - platform_line_oa_settings.channel_id
# - platform_line_oa_settings.channel_secret
# - platform_line_oa_settings.channel_access_token
# - platform_line_oa_settings.login_liff_id
# - platform_line_oa_settings.registration_liff_id

# Store LINE OA values are managed per tenant and stored in D1:
# - line_oa_settings.tenant_id
# - line_oa_settings.basic_id
# - line_oa_settings.channel_id
# - line_oa_settings.channel_secret
# - line_oa_settings.channel_access_token
# - line_oa_settings.login_liff_id
# - line_oa_settings.booking_liff_id

# TODO for next sprint:
# Move hardcoded platform admin credentials, merchant default password, and
# public base URL from src/index.js into Cloudflare Secrets or D1 settings.
