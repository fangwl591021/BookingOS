# BookingOS environment example
#
# Cloudflare D1 is configured as binding `DB` in wrangler.toml.
# Do not commit real tokens, passwords, Channel Secrets, Channel Access Tokens,
# LIFF IDs, or production credentials.

# Cloudflare D1 binding name. This is configured in wrangler.toml, not loaded
# from a local .env file by the Worker.
DB=configured-in-wrangler-toml

# Public URLs. PUBLIC_BASE_URL is used to generate webhook, apply, trial and
# referral links. If omitted, the Worker falls back to the current request origin.
PUBLIC_BASE_URL=https://example.com
DEFAULT_TENANT_ID=demo-tenant

# Platform admin login. Store these as Cloudflare Secrets in production.
PLATFORM_ADMIN_USER=admin@example.com
PLATFORM_ADMIN_PASSWORD=replace-with-secret
PLATFORM_SESSION_SECRET=replace-with-random-session-secret

# Merchant fallback password. Store as Cloudflare Secret in production.
MERCHANT_ADMIN_PASSWORD=replace-with-secret
MERCHANT_IDENTITY_RESOLUTION_ENABLED=true

# BookingOS platform LINE OA. These env values override D1 platform settings
# when present, so production can keep secrets out of stored UI values.
PLATFORM_LINE_BASIC_ID=@example
PLATFORM_LINE_CHANNEL_ID=0000000000
PLATFORM_LINE_CHANNEL_SECRET=replace-with-line-channel-secret
PLATFORM_LINE_CHANNEL_ACCESS_TOKEN=replace-with-line-channel-access-token
PLATFORM_LINE_LOGIN_LIFF_ID=0000000000-xxxxxxxx
PLATFORM_LINE_REGISTRATION_LIFF_ID=0000000000-xxxxxxxx
PLATFORM_LINE_FRIEND_ADD_URL=https://line.me/R/ti/p/@example

# Optional default tenant LINE OA fallback. Prefer D1 per-tenant settings or
# tenant-scoped env names when more than one store has its own OA.
LINE_CHANNEL_SECRET=replace-with-default-tenant-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=replace-with-default-tenant-line-channel-access-token

# Optional tenant-scoped LINE OA secrets. Convert tenant_id to uppercase and
# replace non A-Z/0-9 characters with underscores.
# Example tenant_id `trial-mrd14uce` becomes `TRIAL_MRD14UCE`.
LINE_TRIAL_MRD14UCE_CHANNEL_SECRET=replace-with-tenant-line-channel-secret
LINE_TRIAL_MRD14UCE_CHANNEL_ACCESS_TOKEN=replace-with-tenant-line-channel-access-token